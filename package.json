// ── AUTO RATE: get status ──
router.get('/auto-rate', auth, (req, res) => {
  const db  = getDB();
  const get = key => db.prepare('SELECT value FROM settings WHERE key=?').get(key)?.value || '';
  res.json({
    enabled:      get('auto_enabled') === '1',
    marketRate:   get('auto_market_rate'),
    buySpread:    get('auto_buy_spread'),
    sellSpread:   get('auto_sell_spread'),
    lastFetched:  get('auto_last_fetched'),
    status:       get('auto_scrape_status'),
    buyRate:      get('buy_rate'),
    sellRate:     get('sell_rate'),
  });
});

// ── AUTO RATE: update spreads / toggle ──
router.post('/auto-rate', auth, (req, res) => {
  const { enabled, buySpread, sellSpread } = req.body;
  const db  = getDB();
  const upd = db.prepare('UPDATE settings SET value=?, updated_at=CURRENT_TIMESTAMP WHERE key=?');
  const save = db.transaction(() => {
    if (enabled !== undefined)   upd.run(enabled ? '1' : '0', 'auto_enabled');
    if (buySpread  !== undefined) upd.run(String(buySpread),   'auto_buy_spread');
    if (sellSpread !== undefined) upd.run(String(sellSpread),  'auto_sell_spread');
  });
  save();
  res.json({ success: true });
});

// ── AUTO RATE: trigger manual fetch now ──
router.post('/auto-rate/fetch-now', auth, async (req, res) => {
  try {
    const { scrapeAndUpdate } = require('../services/rateScraper');
    const result = await scrapeAndUpdate();
    if (result) res.json({ success: true, result: result });
    else res.json({ success: false, error: 'Could not parse rate — check scraper status' });
  } catch (e) {
    res.status(500).json({ success: false, error: e.message });
  }
});

module.exports = router;
