const express = require('express');
const router  = express.Router();
const bcrypt  = require('bcryptjs');
const jwt     = require('jsonwebtoken');
const auth    = require('../middleware/auth');
const { getDB } = require('../db/database');

const SECRET = () => process.env.JWT_SECRET || 'gg-secret-change-me';

// ── LOGIN ──
router.post('/login', async (req, res) => {
  const { username, password } = req.body;
  if (!username || !password) return res.status(400).json({ error: 'Username and password required' });
  const db   = getDB();
  const user = db.prepare('SELECT * FROM admin_users WHERE username=?').get(username);
  if (!user) return res.status(401).json({ error: 'Invalid credentials' });
  const valid = await bcrypt.compare(password, user.password_hash);
  if (!valid)  return res.status(401).json({ error: 'Invalid credentials' });
  const token = jwt.sign({ id: user.id, username: user.username, role: 'admin' }, SECRET(), { expiresIn: '8h' });
  res.json({ token, username: user.username });
});

// ── CHANGE PASSWORD ──
router.post('/change-password', auth, async (req, res) => {
  const { currentPassword, newPassword } = req.body;
  if (!currentPassword || !newPassword) return res.status(400).json({ error: 'Both passwords required' });
  if (newPassword.length < 8) return res.status(400).json({ error: 'Password must be at least 8 characters' });
  const db   = getDB();
  const user = db.prepare('SELECT * FROM admin_users WHERE id=?').get(req.admin.id);
  const valid = await bcrypt.compare(currentPassword, user.password_hash);
  if (!valid) return res.status(401).json({ error: 'Current password is wrong' });
  const hash = await bcrypt.hash(newPassword, 12);
  db.prepare('UPDATE admin_users SET password_hash=? WHERE id=?').run(hash, req.admin.id);
  res.json({ success: true });
});

// ── SETTINGS: get all ──
router.get('/settings', auth, (req, res) => {
  const db = getDB();
  const rows = db.prepare('SELECT * FROM settings ORDER BY group_name, key').all();
  // Group them
  const grouped = {};
  rows.forEach(r => {
    const g = r.group_name || 'general';
    if (!grouped[g]) grouped[g] = [];
    grouped[g].push(r);
  });
  res.json(grouped);
});

// ── SETTINGS: update one ──
router.put('/settings/:key', auth, (req, res) => {
  const { value } = req.body;
  if (value === undefined) return res.status(400).json({ error: 'Value required' });
  const db = getDB();
  db.prepare('UPDATE settings SET value=?, updated_at=CURRENT_TIMESTAMP WHERE key=?').run(value, req.params.key);
  res.json({ success: true, key: req.params.key, value });
});

// ── SETTINGS: batch update ──
router.post('/settings/batch', auth, (req, res) => {
  const { updates } = req.body; // { key: value, ... }
  if (!updates) return res.status(400).json({ error: 'Updates object required' });
  const db  = getDB();
  const upd = db.prepare('UPDATE settings SET value=?, updated_at=CURRENT_TIMESTAMP WHERE key=?');
  const updateMany = db.transaction(entries => {
    for (const [key, value] of entries) upd.run(value, key);
  });
  updateMany(Object.entries(updates));
  res.json({ success: true, updated: Object.keys(updates).length });
});

// ── REVIEWS: get all ──
router.get('/reviews', auth, (req, res) => {
  const db = getDB();
  res.json(db.prepare('SELECT * FROM reviews ORDER BY sort_order').all());
});

// ── REVIEWS: create ──
router.post('/reviews', auth, (req, res) => {
  const { name, handle, platform, quote, source_url, initials } = req.body;
  if (!name || !quote) return res.status(400).json({ error: 'Name and quote required' });
  const db = getDB();
  const maxOrder = db.prepare('SELECT MAX(sort_order) as m FROM reviews').get().m || 0;
  const result = db.prepare(`
    INSERT INTO reviews (name, handle, platform, quote, source_url, initials, sort_order)
    VALUES (?, ?, ?, ?, ?, ?, ?)
  `).run(name, handle||'', platform||'', quote, source_url||'', initials||name.slice(0,2).toUpperCase(), maxOrder+1);
  res.json({ success: true, id: result.lastInsertRowid });
});

// ── REVIEWS: update ──
router.put('/reviews/:id', auth, (req, res) => {
  const { name, handle, platform, quote, source_url, initials, active, sort_order } = req.body;
  const db = getDB();
  db.prepare(`
    UPDATE reviews SET name=?, handle=?, platform=?, quote=?, source_url=?, initials=?, active=?, sort_order=?, updated_at=CURRENT_TIMESTAMP
    WHERE id=?
  `).run(name, handle, platform, quote, source_url, initials, active?1:0, sort_order, req.params.id);
  res.json({ success: true });
});

// ── REVIEWS: delete ──
router.delete('/reviews/:id', auth, (req, res) => {
  getDB().prepare('DELETE FROM reviews WHERE id=?').run(req.params.id);
  res.json({ success: true });
});

