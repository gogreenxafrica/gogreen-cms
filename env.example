const Database = require('better-sqlite3');
const path     = require('path');
const bcrypt   = require('bcryptjs');

const DB_PATH = process.env.DB_PATH || path.join(__dirname, 'gogreen.db');
let db;

function getDB() {
  if (!db) db = new Database(DB_PATH);
  return db;
}

async function initDB() {
  const db = getDB();

  // ── TABLES ──
  db.exec(`
    CREATE TABLE IF NOT EXISTS settings (
      key   TEXT PRIMARY KEY,
      value TEXT NOT NULL,
      label TEXT,
      group_name TEXT,
      updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
    );

    CREATE TABLE IF NOT EXISTS reviews (
      id         INTEGER PRIMARY KEY AUTOINCREMENT,
      name       TEXT NOT NULL,
      handle     TEXT,
      platform   TEXT,
      quote      TEXT NOT NULL,
      source_url TEXT,
      initials   TEXT,
      active     INTEGER DEFAULT 1,
      sort_order INTEGER DEFAULT 0,
      updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
    );

    CREATE TABLE IF NOT EXISTS faqs (
      id         INTEGER PRIMARY KEY AUTOINCREMENT,
      question   TEXT NOT NULL,
      answer     TEXT NOT NULL,
      active     INTEGER DEFAULT 1,
      sort_order INTEGER DEFAULT 0,
      updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
    );

    CREATE TABLE IF NOT EXISTS services (
      id          INTEGER PRIMARY KEY AUTOINCREMENT,
      name        TEXT NOT NULL,
      description TEXT NOT NULL,
      icon        TEXT,
      wa_message  TEXT,
      active      INTEGER DEFAULT 1,
      sort_order  INTEGER DEFAULT 0,
      updated_at  DATETIME DEFAULT CURRENT_TIMESTAMP
    );

    CREATE TABLE IF NOT EXISTS admin_users (
      id            INTEGER PRIMARY KEY AUTOINCREMENT,
      username      TEXT UNIQUE NOT NULL,
      password_hash TEXT NOT NULL,
      created_at    DATETIME DEFAULT CURRENT_TIMESTAMP
    );
  `);

  // ── SEED SETTINGS ──
  const settingsSeed = [
    // Rates
    ['buy_rate',   '1388',           'We Buy Rate (₦/$)',     'rates'],
    ['sell_rate',  '1489',           'We Sell Rate (₦/$)',    'rates'],
    // Contact
    ['wa_number',  '2347010975329',  'WhatsApp Number',       'contact'],
    // Social
    ['ig_handle',  'gogreenxafrica', 'Instagram Handle',      'social'],
    ['ig_backup',  'gogreenexchange','Instagram Backup',       'social'],
    ['tiktok',     'gogreenxafrica', 'TikTok Handle',         'social'],
    ['twitter',    'gogreenxafrica', 'Twitter/X Handle',      'social'],
    ['linkedin',   'gogreenxafrica', 'LinkedIn Handle',       'social'],
    // Hero
    ['hero_headline',   'Whatever Digital Money.',            'Hero Headline',   'hero'],
    ['hero_subheading', 'Get Naira. Fast.',                   'Hero Subheading', 'hero'],
    ['hero_sub',        'Whatever digital money you carry — we turn am to naira. Sharp sharp. Crypto, gift cards, CashApp, EUR, transfers and more.', 'Hero Body Text', 'hero'],
    ['hero_badge',      'Live & Trading 24/7',                'Hero Badge Text', 'hero'],
    // Features
    ['feat1_tag',   'Trust & Safety',                         'Feature 1 Tag',   'features'],
    ['feat1_title', 'CAC Registered & Trademarked',           'Feature 1 Title', 'features'],
    ['feat1_body',  'CAC registered, trademarked. 50+ proofs on Instagram. Your money dey safe — no dulling.', 'Feature 1 Body', 'features'],
    ['feat2_tag',   'Speed',                                  'Feature 2 Tag',   'features'],
    ['feat2_title', 'Instant Naira. No Delays.',              'Feature 2 Title', 'features'],
    ['feat2_body',  'Once confirmed, e don enter your account. No stories, no long thing. Faster than your bank fit process am.', 'Feature 2 Body', 'features'],
    ['feat3_tag',   'Coverage',                               'Feature 3 Tag',   'features'],
    ['feat3_title', 'Any Currency. Any Country.',             'Feature 3 Title', 'features'],
    ['feat3_body',  'EUR, USD, UK, Canada, India and more. If digital money dey anywhere for this earth — Gogreen go move am.', 'Feature 3 Body', 'features'],
    // How it works
    ['how_step1_title', 'Tell Us Wetin You Get',              'Step 1 Title', 'how'],
    ['how_step1_body',  'Send us the asset type, amount and your bank details on WhatsApp. No sign-up, no form.', 'Step 1 Body', 'how'],
    ['how_step2_title', 'We Verify Am',                       'Step 2 Title', 'how'],
    ['how_step2_body',  'We confirm your transaction before anything moves. Every trade checked — no rushing.', 'Step 2 Body', 'how'],
    ['how_step3_title', 'E Don Enter',                        'Step 3 Title', 'how'],
    ['how_step3_body',  "Naira lands straight in your account. Fast settlement, zero hidden charges. That's the Gogreen way.", 'Step 3 Body', 'how'],
    // CTA
    ['cta_heading', 'Ready to trade?',                        'CTA Heading',  'cta'],
    ['cta_body',    'Join the Nigerians wey sabi. Digital money movement, done right.', 'CTA Body', 'cta'],
    // Footer
    ['footer_copy', '© 2026 Purplegreen Investment Limited',  'Footer Copyright', 'footer'],
    ['bento_quote', '"Whatever digital money you carry — we move am."', 'Bento Quote', 'bento'],
  ];

  const insertSetting = db.prepare(`
    INSERT OR IGNORE INTO settings (key, value, label, group_name)
    VALUES (?, ?, ?, ?)
  `);
  for (const s of settingsSeed) {
    insertSetting.run(...s);
  }

  // ── SEED REVIEWS ──
  const reviewCount = db.prepare('SELECT COUNT(*) as c FROM reviews').get().c;
  if (reviewCount === 0) {
    const insertReview = db.prepare(`
      INSERT INTO reviews (name, handle, platform, quote, source_url, initials, sort_order)
      VALUES (?, ?, ?, ?, ?, ?, ?)
    `);
    insertReview.run('@opeyemiiii_', '@opeyemiiii_', 'Instagram',
      'Tested and trusted. Emphasis on the fast 🙂‍↕️',
      'https://www.instagram.com/reel/DShQ3wrCClp?comment_id=17911295154146322&open_comments=true',
      'OP', 1);
    insertReview.run('Niki Lauda', 'Niki Lauda', 'TikTok',
      "Omoooo the most reliable vendor ever, never ever disappoints me in any form. I love y'all ❤️",
      'https://vt.tiktok.com/ZS9dy3hYJmKq8-W2yHb/',
      'NL', 2);
    insertReview.run('@winnie_xcx', '@winnie_xcx', 'Instagram',
      'Seamless service, very impressive.',
      'https://www.instagram.com/reel/DShP99GCEII?comment_id=18092244838973814&open_comments=true',
      'WX', 3);
  }

  // ── SEED FAQS ──
  const faqCount = db.prepare('SELECT COUNT(*) as c FROM faqs').get().c;
  if (faqCount === 0) {
    const insertFaq = db.prepare(`
      INSERT INTO faqs (question, answer, sort_order) VALUES (?, ?, ?)
    `);
    insertFaq.run('I have trust issues. Is Gogreen legit?',
      'We understand — plenty scam dey outside. But Gogreen is CAC-registered under Purplegreen Investment Limited. Check @gogreenxafrica on Instagram — 50+ real proofs of real deals. No pressure, whenever you ready, we dey here.', 1);
    insertFaq.run('Do you buy BTC and other crypto?',
      'Yes — BTC, USDT, ETH and more. Send the asset type and amount on WhatsApp, we go give you live rate immediately. Once your coins land, we pay. E no hard.', 2);
    insertFaq.run('How fast is payment?',
      'Instant after confirmation. No delay, no story. We move faster than your bank fit blink.', 3);
    insertFaq.run("What's the process? Step by step.",
      "(1) Send wetin you get + amount on WhatsApp. (2) Collect live rate + wallet address. (3) Send your funds. (4) Alert enter. Simple as that.", 4);
    insertFaq.run('Do you accept PayPal and digital wallets?',
      'Yes — PayPal, CashApp, Chime, Apple Pay, Venmo, GCash, Revolut, Skrill, Neteller, e-Transfer and more. You get one wey you no see? Just ask — we probably accept am.', 5);
    insertFaq.run('Which countries do you cover for transfers?',
      'EUR/SEPA, UK, US, Canada, Australia, Mexico, India, Indonesia, Philippines, Ukraine, Russia and many more. Name the country — chances are we dey cover am.', 6);
    insertFaq.run('Where are you located?',
      'Based in Abeokuta, Ogun State — but we dey everywhere online. Nationwide and worldwide. Hit us on WhatsApp: 07010975329 or find us @gogreenxafrica on any platform.', 7);
  }

  // ── SEED SERVICES ──
  const svcCount = db.prepare('SELECT COUNT(*) as c FROM services').get().c;
  if (svcCount === 0) {
    const insertSvc = db.prepare(`
      INSERT INTO services (name, description, icon, wa_message, sort_order)
      VALUES (?, ?, ?, ?, ?)
    `);
    insertSvc.run('Crypto', 'USDT, USDC, SOL, BTC, ETH and more. Best rates, instant naira payout.', 'crypto', 'Crypto', 1);
    insertSvc.run('Gift Cards', 'Amazon, iTunes, Steam, Google Play and more. We buy them all.', 'gift', 'Gift Cards', 2);
    insertSvc.run('CashApp', 'Send your CashApp balance. Receive naira straight to your bank.', 'cashapp', 'CashApp', 3);
    insertSvc.run('EUR Payments', 'Got euros? We convert and settle at competitive rates.', 'eur', 'EUR Payments', 4);
    insertSvc.run('USA Transfers', 'Receive funds from the US fast. No stress, no delays.', 'transfer', 'USA Transfers', 5);
    insertSvc.run('Cash Mailing', 'Physical cash movement handled securely and discreetly.', 'cash', 'Cash Mailing', 6);
    insertSvc.run('Wire Transfers', 'International wire payments processed with speed and reliability.', 'wire', 'Wire Transfers', 7);
    insertSvc.run('All-Country Transfers', 'Any country, any corridor. If money moves, we move it.', 'globe', 'All-Country Transfers', 8);
  }

  // ── SEED ADMIN USER ──
  const adminCount = db.prepare('SELECT COUNT(*) as c FROM admin_users').get().c;
  if (adminCount === 0) {
    const pass = process.env.ADMIN_PASS || 'gogreen2026';
    const hash = await bcrypt.hash(pass, 12);
    db.prepare('INSERT INTO admin_users (username, password_hash) VALUES (?, ?)')
      .run('admin', hash);
    console.log(`👤 Admin user created — username: admin, password: ${pass}`);
  }

  console.log('✅ Database ready');
}

module.exports = { getDB, initDB };
