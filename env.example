const express = require('express');
const router  = express.Router();
const { all, get } = require('../db/database');

router.get('/', async (req, res) => {
  try {
    const [settings, reviews, faqs, services] = await Promise.all([
      all('SELECT key, value FROM settings'),
      all('SELECT * FROM reviews WHERE active=1 ORDER BY sort_order'),
      all('SELECT * FROM faqs WHERE active=1 ORDER BY sort_order'),
      all('SELECT * FROM services WHERE active=1 ORDER BY sort_order'),
    ]);
    const s = {};
    settings.forEach(r => s[r.key] = r.value);
    res.json({ settings: s, reviews, faqs, services });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

router.get('/rates', async (req, res) => {
  try {
    const buy  = await get("SELECT value FROM settings WHERE key='buy_rate'");
    const sell = await get("SELECT value FROM settings WHERE key='sell_rate'");
    const wa   = await get("SELECT value FROM settings WHERE key='wa_number'");
    res.json({ buy_rate: buy?.value, sell_rate: sell?.value, wa_number: wa?.value });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

module.exports = router;
